+          </div>
+          <span class="ellipsis-one-line main-type-mestoBold">${customAppData.name}</span>
+      </a>
+  </li>`;
+		customAppHtmls.push(customAppHtml);
+	}
+	return customAppHtmls.join("");
+}
+function createPlaylistHtml(newPlaylistHtml) {
+	if (!newPlaylistHtml) return;
